# ── AutoCount Source Database (AWS RDS) ──────────────────────────────────────
# Get this from Bitwarden shared vault → "HY Finance Demo — RDS Credentials"
AUTOCOUNT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/autocount?sslmode=no-verify

# ── Local PostgreSQL (Docker) ────────────────────────────────────────────────
# These are local-only — no need to change
POSTGRES_LOCAL_PASSWORD=hoiyong_dev_2026
DATABASE_URL=postgres://hoiyong:hoiyong_dev_2026@localhost:5433/hoiyong

# ── RDS Direct (optional — enables drill-down into invoice details) ──────────
# Same credentials as AUTOCOUNT_DATABASE_URL above. Leave blank to skip drill-down.
RDS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/autocount?sslmode=no-verify

# ── Sync Service ─────────────────────────────────────────────────────────────
SYNC_SERVICE_URL=http://localhost:4000
